{
  "name": "@fratzinger/feathers-kysely",
  "description": "Feathers SQL service adapter using Kysely",
  "version": "0.7.0",
  "homepage": "https://github.com/fratzinger/feathers-kysely",
  "keywords": [
    "feathers",
    "feathers-plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fratzinger/feathers-kysely.git"
  },
  "author": {
    "name": "Frederik Schmatz"
  },
  "contributors": [],
  "bugs": {
    "url": "https://github.com/fratzinger/feathers-kysely/issues"
  },
  "engines": {
    "node": ">= 22"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "version": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint",
    "vitest": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@feathersjs/adapter-commons": "^5.0.44",
    "@feathersjs/commons": "^5.0.44",
    "@feathersjs/errors": "^5.0.44",
    "@feathersjs/feathers": "^5.0.44",
    "feathers-utils": "^10.0.2"
  },
  "devDependencies": {
    "@feathers-community/eslint-config": "^0.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "feathers-adapter-vitest": "^0.0.17",
    "feathers-hooks-common": "^8.2.1",
    "kysely": "^0.29.2",
    "mysql2": "^3.22.4",
    "pg": "^8.21.0",
    "shx": "^0.4.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "unrun": "^0.3.0",
    "vite": "^8.0.15",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@feathersjs/feathers": "^5.0.0",
    "kysely": ">=0.28.0 <0.30.0"
  },
  "packageManager": "pnpm@11.5.1"
}
