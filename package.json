{
  "name": "@fratzinger/feathers-kysely",
  "description": "Feathers SQL service adapter using Kysely",
  "version": "0.5.1",
  "homepage": "https://github.com/fratzinger/feathers-kysely",
  "keywords": [
    "feathers",
    "feathers-plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fratzinger/feathers-kysely.git"
  },
  "author": {
    "name": "Frederik Schmatz"
  },
  "contributors": [],
  "bugs": {
    "url": "https://github.com/marshallswain/feathers-kysely/issues"
  },
  "engines": {
    "node": ">= 14"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "src/**",
    "dist/**",
    "*.d.ts",
    "*.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "version": "pnpm build",
    "test": "vitest run",
    "lint": "eslint",
    "vitest": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@feathersjs/adapter-commons": "^5.0.44",
    "@feathersjs/commons": "^5.0.44",
    "@feathersjs/errors": "^5.0.44",
    "@feathersjs/feathers": "^5.0.44",
    "feathers-utils": "^10.0.0"
  },
  "devDependencies": {
    "@feathers-community/eslint-config": "^0.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "feathers-adapter-vitest": "^0.0.17",
    "feathers-hooks-common": "^8.2.1",
    "kysely": "^0.29.0",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "shx": "^0.4.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unrun": "^0.3.0",
    "vite": "^8.0.12",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@feathersjs/feathers": "^5.0.0",
    "kysely": "^0.28.0"
  },
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
